# MrFoX-MeM environment — copy to .env and adjust.
# These are read by the hooks and the MCP server. The core API binds to
# 127.0.0.1 only; do NOT point MRFOX_API at a non-localhost host.
#
# Cross-OS note: the hook command in .claude/settings.json invokes the
# interpreter as `python3` on macOS/Linux but `python` on Windows. See
# hooks/settings.snippet.json (mac/Linux) and
# hooks/settings.snippet.windows.json (Windows).

# Base URL of the running core API (FastAPI). Localhost only.
MRFOX_API=http://127.0.0.1:8077

# Default project slug used by hooks and the MCP server when none is given.
MRFOX_PROJECT=my-project

# Optional hardening: restrict which directories /ingest may read, as an
# os.pathsep-separated allow-list of absolute roots. When unset, ingestion is
# allowed anywhere EXCEPT credential/system dirs (~/.ssh, ~/.aws, /etc, ...).
# Example: MRFOX_ALLOWED_ROOTS=/Users/me/code:/Users/me/work
# MRFOX_ALLOWED_ROOTS=

# Port the core API listens on (read by `python -m core.run`). Note: `make
# serve` and run.sh currently hardcode 8077 — change there too if you alter it.
# MRFOX_PORT=8077
